{
  "name": "level-loop",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo/metro-runtime": "~56.0.12",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "expo": "~56.0.13",
    "expo-audio": "~56.0.12",
    "expo-blur": "^56.0.3",
    "expo-font": "^56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "^56.0.4",
    "expo-notifications": "~56.0.19",
    "expo-splash-screen": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File scripts/android-dev-connect.ps1; expo start",
    "tunnel": "expo start --tunnel",
    "lan": "expo start --lan",
    "android": "powershell -ExecutionPolicy Bypass -File scripts/android-run.ps1",
    "android:connect": "powershell -ExecutionPolicy Bypass -File scripts/android-dev-connect.ps1",
    "android:fix-adb": "powershell -ExecutionPolicy Bypass -Command \"$adb = Join-Path $env:LOCALAPPDATA 'Android\\Sdk\\platform-tools\\adb.exe'; & $adb kill-server; Start-Sleep -Seconds 2; & $adb start-server; Start-Sleep -Seconds 2; & $adb devices\"",
    "android:legacy": "powershell -ExecutionPolicy Bypass -File scripts/android-dev-connect.ps1; expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "android:apk": "expo run:android --variant release",
    "android:apk:debug": "expo run:android --variant debug",
    "clear": "expo start --clear",
    "clear:cache": "node scripts/clear-metro-cache.mjs",
    "sync-ip": "node scripts/sync-api-ip.mjs"
  },
  "private": true
}
