DATABASE_URL=postgresql://usuario:password@host/db?sslmode=require
JWT_SECRET=change-me-in-local-dev
PORT=3000
FRONTEND_ORIGIN=http://localhost:8082

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxx

# Modo prueba (onboarding@resend.dev): solo envía al email de tu cuenta Resend.
# Para enviar a CUALQUIER correo (francisco@gmail.com, etc.):
#   1. Ve a https://resend.com/domains y agrega tu dominio
#   2. Configura los registros DNS (SPF, DKIM)
#   3. Cambia EMAIL_FROM a un correo de ese dominio, por ejemplo:
#      EMAIL_FROM=Level Loop <noreply@tudominio.com>
EMAIL_FROM=Level Loop <onboarding@resend.dev>
APP_NAME=Level Loop

# Modo prueba sin dominio: reenvía cualquier correo de verificación a tu Gmail de Resend.
EMAIL_DEV_REDIRECT_TO=acanche044@gmail.com

# Solo si el envío falla: muestra el código en consola / app (respaldo).
EMAIL_DEV_FALLBACK=true
EMAIL_EXPOSE_DEV_CODE=false
